        <FIELD NAME="target_criteria" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="JSON-encoded targeting criteria"/>
        <FIELD NAME="scheduled_time" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="When campaign should be sent"/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="draft" SEQUENCE="false" COMMENT="Status: draft, scheduled, sending, sent"/>
        <FIELD NAME="ab_testing" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="A/B testing enabled"/>
        <FIELD NAME="created_by" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="User who created campaign"/>
