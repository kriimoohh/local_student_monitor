    <TABLE NAME="local_sm_campaign_recipients" COMMENT="Campaign recipient tracking">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="campaign_id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Campaign ID"/>
